from ultralytics import YOLO
import cv2

# Load YOLOv8 model (auto-downloads if missing)
model = YOLO("yolov8n.pt")

# List of images to detect fire/smoke in
images = ["fire.jpg", "smoke.jpg"]

for image_file in images:
    img = cv2.imread(image_file)
    
    if img is None:
        print(f"Error: {image_file} not found!")
        continue
    
    results = model(img)
    results[0].show()

